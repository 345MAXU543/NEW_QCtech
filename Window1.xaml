<Window x:Class="NEW_QCtech.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
         xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:NEW_QCtech"
        mc:Ignorable="d"
        Title="Window1" Height="1000" Width="1600" WindowStartupLocation="CenterScreen">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
        CaptionHeight="0"
        ResizeBorderThickness="8"
        CornerRadius="0"
        GlassFrameThickness="0"
        UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <ContextMenu x:Key="PlotContextMenu">
            <MenuItem Header="曲線圖設定" />
        </ContextMenu>

        <ContextMenu x:Key="CardsPanelContextMenu">
            <MenuItem Header="數據顯示卡設定"  Click="CardsPanel_Setting"/>
        </ContextMenu>
    </Window.Resources>


    <Grid x:Name="MainWindow_PeripheryGrid" Background="#FF5696AB">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- alert -->
            <RowDefinition Height="Auto"/>
            <!-- 即時資訊 -->
            <RowDefinition Height="5"/>
            <!-- splitter -->
            <RowDefinition Height="*"/>
            <!-- ★ 主工作區 -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <!-- footer -->
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10"/>
            <!-- 左邊框 -->
            <ColumnDefinition/>
            <!-- 主工作區 -->
            <ColumnDefinition Width="Auto" MinWidth="480"/>
            <!-- 右上控制列 -->
            <ColumnDefinition Width="10"/>
            <!-- 右邊框 -->

        </Grid.ColumnDefinitions>

        <Label x:Name="label_Alert"
               Grid.Row="0" Grid.Column="0" Grid.RowSpan="1" Grid.ColumnSpan="2"
               Content="警告訊息 或是 狀態" FontSize="16"  Background="Transparent" Margin="0,0,0,3"  MouseMove="label_Alert_MouseMove"/>

        <!--新增檔案 儲存 另存新檔 開啟檔案 最小化 最大化 叉叉控制箱-->
        <Border Grid.Column="2" Grid.ColumnSpan="1" Background="#FF65735F"  Grid.Row="0" Margin="0,5,0,0" MinWidth="160">
            <Grid>
                <Grid.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF5696AB"/>
                        <GradientStop Color="#FF222838" Offset="1"/>
                        <GradientStop Color="#FF222838" Offset="0.26"/>
                    </LinearGradientBrush>
                </Grid.Background>
                <Grid.ColumnDefinitions>
                    <!-- 左側工具列：永遠 auto -->
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>

                    <!-- 中間：唯一可被壓縮的區域 -->
                    <ColumnDefinition Width="*" MinWidth="0"/>

                    <!-- 右側視窗控制鍵：永遠顯示 -->
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="🗋" FontSize="20" Width="40" Height="30" Background="Transparent" Foreground="White" BorderBrush="#FFB2CBF6" HorizontalAlignment="Left" BorderThickness="1,1,1,0" />
                <Button Grid.Column="1" Content="💾" FontSize="20" Width="40" Height="30" Background="Transparent" Foreground="White" BorderBrush="#FFB2CBF6" HorizontalAlignment="Left" BorderThickness="1,1,1,0"/>
                <Button Grid.Column="2" Content="🗄" FontSize="20" Width="40" Height="30" Background="Transparent" Foreground="White" BorderBrush="#FFB2CBF6" HorizontalAlignment="Left" BorderThickness="1,1,1,0" />
                <Button Grid.Column="3" Content="📂" FontSize="20" Width="40" Height="30" Background="Transparent" Foreground="White" BorderBrush="#FFB2CBF6" HorizontalAlignment="Left" BorderThickness="1,1,1,0" />

                <Grid Grid.Column ="4" Height="30" Margin="5,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="1*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Image x:Name="Image_CompanyTrademark" Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"  Height="30" Width="30"  VerticalAlignment="Center" Source="/13.png" Stretch="Fill" RenderTransformOrigin="0.5,0.5" HorizontalAlignment="Left" />
                    <Label  Grid.Column="1" Grid.Row="0" Grid.RowSpan="2" Content="Yang YI" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="5,0,0,0" Padding="0,0,0,0"/>
                    <Label Grid.Column="3" Grid.Row="1" Content="technology" FontSize="10" Foreground="White" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5,0,0,0" Padding="0,0,0,0"/>


                </Grid>

                <Button x:Name="btn_GlobalSetting" Grid.Column="5" Content="S" FontSize="20" Width="40" Height="30" Background="Transparent" Foreground="White" BorderBrush="#FFB2CBF6" HorizontalAlignment="Right" BorderThickness="1,1,1,0" />
                <Button Grid.Column="6" Content="🗕" FontSize="20" Width="40" Height="30" Background="Transparent" Foreground="White" BorderBrush="#FFB2CBF6" HorizontalAlignment="Right" BorderThickness="1,1,1,0" />
                <Button Grid.Column="7" Content="🗗" FontSize="20" Width="40" Height="30" Background="Transparent" Foreground="White" BorderBrush="#FFB2CBF6" HorizontalAlignment="Right" BorderThickness="1,1,1,0"/>
                <Button Grid.Column="8" Content="✕" FontSize="20" Width="40" Height="30" Background="Transparent" Foreground="White" BorderBrush="#FFB2CBF6" HorizontalAlignment="Right" BorderThickness="1,1,1,0" />
            </Grid>
        </Border>

        <!--放即時資訊-->
        <Border Grid.Row="1" Grid.ColumnSpan="3" Background="#FF4B4B52" Margin="10,0,0,0">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" AllowDrop="True"
                  VerticalScrollBarVisibility="Disabled" Margin="0,0,0,0">
                <ScrollViewer.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF3A4560" Offset="0.0"/>
                        <GradientStop Color="#FF1E2433" Offset="0.18"/>
                        <GradientStop Color="#FF0E0E13" Offset="0.50"/>
                        <GradientStop Color="#FF1E2433" Offset="0.82"/>
                        <GradientStop Color="#FF3A4560" Offset="1.0"/>
                    </LinearGradientBrush>
                </ScrollViewer.Background>
                <WrapPanel x:Name="CardsPanel" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center"  
                            AllowDrop="True"
        ContextMenu="{StaticResource CardsPanelContextMenu}">
                    <Border Margin="0" Tag="Card" Background="Transparent">
                        <Viewbox>
                            <Grid Margin="10" Width="350" Height="130">
                                <!-- 陰影 -->
                                <Grid.Effect>
                                    <DropShadowEffect ShadowDepth="15" BlurRadius="15" Opacity="0.4"/>
                                </Grid.Effect>

                                <!-- 版面 -->
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="2*"/>
                                    <RowDefinition Height="1*"/>
                                </Grid.RowDefinitions>

                                <!-- 背景（整張卡） -->
                                <Grid
Grid.RowSpan="2"
Grid.ColumnSpan="3">
                                    <Grid.Background>
                                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                            <LinearGradientBrush.RelativeTransform>
                                                <TransformGroup>
                                                    <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                                                    <SkewTransform CenterX="0.5" CenterY="0.5"/>
                                                    <RotateTransform Angle="-45" CenterX="0.5" CenterY="0.5"/>
                                                    <TranslateTransform/>
                                                </TransformGroup>
                                            </LinearGradientBrush.RelativeTransform>
                                            <GradientStop Color="#FF0A5400"/>
                                            <GradientStop Color="#FF49A23D" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Grid.Background>
                                </Grid>

                                <!-- 大數字 -->
                                <Viewbox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Left">
                                    <Label Grid.Row="0" Grid.Column="0" Content="00" FontWeight="Bold" Foreground="White" Padding="2,0,2,0"/>
                                </Viewbox>

                                <!-- 小標題 -->
                                <Viewbox  Grid.Row="1" Grid.Column="0" HorizontalAlignment="Left">
                                    <Label Content="Axie1 Position(mm)" Foreground="White" Padding="5,0,0,0"/>
                                </Viewbox>


                                <!-- 右側圖示（最簡單：Emoji） -->
                                <Label Grid.RowSpan="2" Grid.Column="2"
 Content="🏋️"
 FontSize="40"
 Foreground="White"
 HorizontalContentAlignment="Center"
 VerticalContentAlignment="Bottom"/>
                            </Grid>
                        </Viewbox>
                    </Border>

                    <Border Margin="0" Tag="Card" Background="Transparent">
                        <Viewbox>
                            <Grid Margin="10" Width="350" Height="130">
                                <!-- 陰影 -->
                                <Grid.Effect>
                                    <DropShadowEffect ShadowDepth="15" BlurRadius="15" Opacity="0.4"/>
                                </Grid.Effect>

                                <!-- 版面 -->
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="2*"/>
                                    <RowDefinition Height="1*"/>
                                </Grid.RowDefinitions>

                                <!-- 背景（整張卡） -->
                                <Grid
Grid.RowSpan="2"
Grid.ColumnSpan="3">
                                    <Grid.Background>
                                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                            <LinearGradientBrush.RelativeTransform>
                                                <TransformGroup>
                                                    <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                                                    <SkewTransform CenterX="0.5" CenterY="0.5"/>
                                                    <RotateTransform Angle="-45" CenterX="0.5" CenterY="0.5"/>
                                                    <TranslateTransform/>
                                                </TransformGroup>
                                            </LinearGradientBrush.RelativeTransform>
                                            <GradientStop Color="#FF0A5400"/>
                                            <GradientStop Color="#FF49A23D" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Grid.Background>
                                </Grid>

                                <!-- 大數字 -->
                                <Viewbox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Left">
                                    <Label Grid.Row="0" Grid.Column="0" Content="00,0.0000000" FontWeight="Bold" Foreground="White" Padding="2,0,2,0"/>
                                </Viewbox>

                                <!-- 小標題 -->
                                <Viewbox  Grid.Row="1" Grid.Column="0" HorizontalAlignment="Left">
                                    <Label Content="Axie2 Position(mm)" Foreground="White" Padding="5,0,0,0"/>
                                </Viewbox>


                                <!-- 右側圖示（最簡單：Emoji） -->
                                <Label Grid.RowSpan="2" Grid.Column="2"
 Content="🏋️"
 FontSize="40"
 Foreground="White"
 HorizontalContentAlignment="Center"
 VerticalContentAlignment="Bottom"/>
                            </Grid>
                        </Viewbox>
                    </Border>


                    <Border Margin="0" Tag="Card" Background="Transparent">
                        <Viewbox>
                            <Grid Margin="10" Width="350" Height="130">
                                <!-- 陰影 -->
                                <Grid.Effect>
                                    <DropShadowEffect ShadowDepth="15" BlurRadius="15" Opacity="0.4"/>
                                </Grid.Effect>

                                <!-- 版面 -->
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="2*"/>
                                    <RowDefinition Height="1*"/>
                                </Grid.RowDefinitions>

                                <!-- 背景（整張卡） -->
                                <Grid
Grid.RowSpan="2"
Grid.ColumnSpan="3">
                                    <Grid.Background>
                                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                            <LinearGradientBrush.RelativeTransform>
                                                <TransformGroup>
                                                    <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                                                    <SkewTransform CenterX="0.5" CenterY="0.5"/>
                                                    <RotateTransform Angle="-45" CenterX="0.5" CenterY="0.5"/>
                                                    <TranslateTransform/>
                                                </TransformGroup>
                                            </LinearGradientBrush.RelativeTransform>
                                            <GradientStop Color="#FF0A5400"/>
                                            <GradientStop Color="#FF49A23D" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Grid.Background>
                                </Grid>

                                <!-- 大數字 -->
                                <Viewbox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Left">
                                    <Label Grid.Row="0" Grid.Column="0" Content="00,0.0000000" FontWeight="Bold" Foreground="White" Padding="2,0,2,0"/>
                                </Viewbox>

                                <!-- 小標題 -->
                                <Viewbox  Grid.Row="1" Grid.Column="0" HorizontalAlignment="Left">
                                    <Label Content="Axie2 Position(mm)" Foreground="White" Padding="5,0,0,0"/>
                                </Viewbox>


                                <!-- 右側圖示（最簡單：Emoji） -->
                                <Label Grid.RowSpan="2" Grid.Column="2"
 Content="🏋️"
 FontSize="40"
 Foreground="White"
 HorizontalContentAlignment="Center"
 VerticalContentAlignment="Bottom"/>
                            </Grid>
                        </Viewbox>
                    </Border>


                    <Border Margin="0" Tag="Card" Background="Transparent">
                        <Viewbox>
                            <Grid Margin="10" Width="350" Height="130">
                                <!-- 陰影 -->
                                <Grid.Effect>
                                    <DropShadowEffect ShadowDepth="15" BlurRadius="15" Opacity="0.4"/>
                                </Grid.Effect>

                                <!-- 版面 -->
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="2*"/>
                                    <RowDefinition Height="1*"/>
                                </Grid.RowDefinitions>

                                <!-- 背景（整張卡） -->
                                <Grid
Grid.RowSpan="2"
Grid.ColumnSpan="3">
                                    <Grid.Background>
                                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                            <LinearGradientBrush.RelativeTransform>
                                                <TransformGroup>
                                                    <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                                                    <SkewTransform CenterX="0.5" CenterY="0.5"/>
                                                    <RotateTransform Angle="-45" CenterX="0.5" CenterY="0.5"/>
                                                    <TranslateTransform/>
                                                </TransformGroup>
                                            </LinearGradientBrush.RelativeTransform>
                                            <GradientStop Color="#FF0A5400"/>
                                            <GradientStop Color="#FF49A23D" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Grid.Background>
                                </Grid>

                                <!-- 大數字 -->
                                <Viewbox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Left">
                                    <Label Grid.Row="0" Grid.Column="0" Content="00,0.0000000" FontWeight="Bold" Foreground="White" Padding="2,0,2,0"/>
                                </Viewbox>

                                <!-- 小標題 -->
                                <Viewbox  Grid.Row="1" Grid.Column="0" HorizontalAlignment="Left">
                                    <Label Content="Axie2 Position(mm)" Foreground="White" Padding="5,0,0,0"/>
                                </Viewbox>


                                <!-- 右側圖示（最簡單：Emoji） -->
                                <Label Grid.RowSpan="2" Grid.Column="2"
 Content="🏋️"
 FontSize="40"
 Foreground="White"
 HorizontalContentAlignment="Center"
 VerticalContentAlignment="Bottom"/>
                            </Grid>
                        </Viewbox>
                    </Border>


                </WrapPanel>
            </ScrollViewer>
        </Border>

        <GridSplitter Grid.Row="2"  HorizontalAlignment="Stretch" Grid.ColumnSpan="3" Margin="10
,0,0,0" Grid.RowSpan="1" >
            <GridSplitter.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0" Opacity="0.5">
                    <LinearGradientBrush.RelativeTransform>
                        <TransformGroup>
                            <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                            <SkewTransform CenterX="0.5" CenterY="0.5"/>
                            <RotateTransform Angle="90" CenterX="0.5" CenterY="0.5"/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </LinearGradientBrush.RelativeTransform>
                    <GradientStop Color="White" Offset="0.004"/>
                    <GradientStop Color="#FF4F73D2" Offset="1"/>
                </LinearGradientBrush>
            </GridSplitter.Background>
        </GridSplitter>

        <!--各類介面-->

        <Border Grid.Row="3" Grid.ColumnSpan="2" Grid.Column="1" Margin="0,0,0,0">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF101118"/>
                    <GradientStop Color="#FF262D3F" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
           
        </Border>
        
        <Image Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" x:Name="Image_MainWorkArea" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Source="/MainPageBG.png" Opacity="0.3"/>
        <Frame x:Name="Frame_MainWorkArea" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,0" Background="Transparent" NavigationUIVisibility="Hidden" Loaded="Frame_MainWorkArea_Loaded"/>


        <Label Grid.Row="5" Content="information" FontSize="15" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center" Height="25" Width="114" Grid.Column="1"/>
        <Label Grid.Row="5" Grid.Column="2" FontSize="15" HorizontalAlignment="Right" Content="Version" Margin="0,2,0,0" Height="25" Width="74" />

    </Grid>

</Window>
