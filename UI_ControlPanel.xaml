<Window x:Class="NEW_QCtech.UI_ControlPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NEW_QCtech"
        mc:Ignorable="d"
        Title="UI_ControlPanel" Height="400" Width="200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height= "1*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

      


        <WrapPanel Grid.Column="0" Grid.Row="0" UseLayoutRounding="False">
            <Button  Content="Up" Width="180" Height="30" Margin="3"/>
            <Button  Content="down" Width="180" Height="30" Margin="3"/>
            <Slider Width="120" Height="30" Margin="3" />
            <TextBox Width="60" Height="30" Margin="3" />
            <Button  Content="Start" Width="150" Height="30" Margin="3"/>
            <Button  Content="stop" Width="150" Height="30" Margin="3"/>
            <Button  Content="Dog" Width="150" Height="30" Margin="3"/>
            <Button  Content="RSZ" Width="150" Height="30" Margin="3"/>
        </WrapPanel>
    </Grid>
    


</Window>
