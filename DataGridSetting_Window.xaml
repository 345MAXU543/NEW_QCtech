<Window x:Class="NEW_QCtech.DataGridSetting_Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:NEW_QCtech"
        Title="DataGrid Setting" Height="520" Width="980"
        WindowStartupLocation="CenterOwner">

    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="#FF6F4200" Offset="1"/>
            <GradientStop Color="#FF0B5D08" Offset="0"/>
            <GradientStop Color="#FF9FA525" Offset="0.475"/>
        </LinearGradientBrush>
    </Window.Background>

    <Window.Resources>
        <!-- Header 顯示 ColumnConfig.Header -->
        <DataTemplate x:Key="ColHeaderTemplate">
            <TextBlock Text="{Binding Header}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </DataTemplate>

        <!-- ✅ Group Header 文字：Converter 直接算（不再用 Loaded + FindVisualChild） -->
        <local:GroupHeaderTextConverter x:Key="GroupHeaderTextConverter"/>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- B 區：TreeView -->
        <Border Grid.Column="0" Background="#80222838" CornerRadius="8" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="B) Available"
                           Foreground="White" FontSize="16" FontWeight="Bold"/>

                <TreeView Grid.Row="2"
                          x:Name="tvCatalog"
                          ItemsSource="{Binding CatalogRoots}"
                          SelectedItemChanged="tvCatalog_SelectedItemChanged"
                          Background="#00222838"
                          Foreground="White"
                          BorderThickness="0">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding Title}" Foreground="White"/>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>

                <Button Grid.Row="4" Height="36"
                        Content="ADD"
                        Click="btnAdd_Click"
                        Background="#FF3D496B" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" />
            </Grid>
        </Border>

        <!-- A 區：Preview DataGrid -->
        <Border Grid.Column="2" Background="#80222838" CornerRadius="8" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="A) Selected Columns (click column header to select)"
                           Foreground="White" FontSize="16" FontWeight="Bold"/>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Width="46" Height="34" Content="←" Click="btnLeft_Click"
                            Margin="0,0,8,0"
                            Background="#FF3D496B" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                    <Button Width="46" Height="34" Content="→" Click="btnRight_Click"
                            Margin="0,0,8,0"
                            Background="#FF3D496B" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                    <Button Width="46" Height="34" Content="🗑️" Click="btnDelete_Click"
                            Background="#FF3D496B" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                </StackPanel>

                <DataGrid Grid.Row="4"
                          x:Name="dgPreview"
                          ItemsSource="{Binding PreviewView}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          Background="#00222838"
                          BorderThickness="0"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          RowHeight="32"
                          ColumnHeaderHeight="36"
                          Foreground="White"
                          PreviewMouseDown="dgPreview_PreviewMouseDown">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#FF3D496B"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="ContentTemplate" Value="{StaticResource ColHeaderTemplate}"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#553D496B"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <!-- ✅ Group：Header 用 Converter 算（不再用 code-behind 找 txtHeader） -->
                    <DataGrid.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.ContainerStyle>
                                <Style TargetType="{x:Type GroupItem}">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type GroupItem}">
                                                <Expander IsExpanded="True" Background="#10222838">
                                                    <Expander.Header>
                                                        <TextBlock FontWeight="Bold" Foreground="White">
                                                            <TextBlock.Text>
                                                                <MultiBinding Converter="{StaticResource GroupHeaderTextConverter}">
                                                                    <!-- 0: group 本體 -->
                                                                    <Binding />
                                                                    <!-- 1: 取得 Window 的 Grouping / SelectedMetrics -->
                                                                    <Binding Path="Grouping" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </Expander.Header>

                                                    <ItemsPresenter TextElement.Foreground="White"/>
                                                </Expander>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </GroupStyle.ContainerStyle>
                        </GroupStyle>
                    </DataGrid.GroupStyle>

                </DataGrid>
            </Grid>
        </Border>

        <!-- C 區 -->
        <Border Grid.Column="4" Background="#80222838" CornerRadius="8" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>

                <GroupBox Grid.Row="0" Header="C1) Column Properties"
                          Foreground="White" BorderBrush="#FF3D496B">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                                   Text="{Binding ColumnEditorHint}"
                                   Foreground="#FFDDDDDD"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Header:" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Height="26"
                                 Text="{Binding SelectedColumn.Header, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding HasSelectedColumn}"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Format:" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="6" Grid.Column="1" Height="26"
                                 Text="{Binding SelectedColumn.Format, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding HasSelectedColumn}"/>

                        <TextBlock Grid.Row="8" Grid.Column="0" Text="OK/NG:" VerticalAlignment="Center"/>
                        
                        
                        <TextBox Grid.Row="8" Grid.Column="1" Height="26"
                                 Text="{Binding SelectedColumn.OkNgRule, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding HasSelectedColumn}"/>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="2" Header="C2) Grouping"
                          Foreground="White" BorderBrush="#FF3D496B">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="1*"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <CheckBox Grid.Row="0"
                                  Content="Enable Grouping"
                                  IsChecked="{Binding Grouping.Enabled, Mode=TwoWay}"
                                  Foreground="White"/>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Group Key:" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" Height="28"
                                      ItemsSource="{Binding GroupKeyCandidates}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding Grouping.GroupKey1FieldId, Mode=TwoWay}"/>
                        </Grid>

                        <TextBlock Grid.Row="4" Text="Group Header Metrics:" Foreground="#FFDDDDDD"/>

                        <ListBox Grid.Row="6"
                                 x:Name="lbMetrics"
                                 ItemsSource="{Binding Grouping.SelectedMetrics}"
                                 SelectedItem="{Binding Grouping.SelectedMetric, Mode=TwoWay}"
                                 DisplayMemberPath="Display"
                                 Background="#10222838"
                                 Foreground="White"
                                 BorderThickness="0"/>

                        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Up" Width="60" Height="30" Margin="0,0,8,0"
                                    Click="btnMetricUp_Click"
                                    Background="#FF3D496B" Foreground="White" BorderThickness="0"/>
                            <Button Content="Down" Width="60" Height="30" Margin="0,0,8,0"
                                    Click="btnMetricDown_Click"
                                    Background="#FF3D496B" Foreground="White" BorderThickness="0"/>
                            <Button Content="Remove" Width="80" Height="30"
                                    Click="btnMetricRemove_Click"
                                    Background="#FF3D496B" Foreground="White" BorderThickness="0"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>
            </Grid>
        </Border>
    </Grid>
</Window>