<Page x:Class="NEW_QCtech.Page_PlotSetting"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:NEW_QCtech"
      mc:Ignorable="d" 
      d:DesignHeight="484" d:DesignWidth="1215"
      Title="Page_PlotSetting" Loaded="Page_Loaded">

    <Grid x:Name="Grid01">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="SlideTransform" Y="-0"/>
        </Grid.RenderTransform>

        <Grid.Background>
            <SolidColorBrush Color="#FF6B905A" Opacity="0.48"/>
        </Grid.Background>
        <Button x:Name="btn_ExitPage" Content="完成" Margin="1068,428,15,14" Click="Button_Click" FontSize="24"/>
        <RadioButton GroupName="A" x:Name="RadioBtn_01" Content="僅Plot1" Margin="473,142,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="24" Height="29" Foreground="White" />
        <RadioButton GroupName="A" x:Name="RadioBtn_02" Content="僅Plot2" Margin="473,186,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="24" Height="29" Foreground="White"/>
        <RadioButton GroupName="A" x:Name="RadioBtn_03" Content="左Plot1 右plot2" Margin="473,227,0,228" HorizontalAlignment="Left" FontSize="24" d:LayoutOverrides="Height" Foreground="White" IsChecked="True"/>
        <RadioButton GroupName="A" x:Name="RadioBtn_04" Content="左Plot2 右plot1" Margin="473,267,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="24" Foreground="White"/>

    </Grid>
</Page>
