<Page x:Class="NEW_QCtech.Page_Login"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:NEW_QCtech"
      mc:Ignorable="d" 
      d:DesignHeight="768" d:DesignWidth="1580"
      Title="Page_Login" Loaded="Page_Loaded">

    <Grid x:Name="RootGrid" Opacity="0">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="PageTransform" X="200"/>
        </Grid.RenderTransform>
        <Canvas Margin="0">
            <Label HorizontalContentAlignment="Center" VerticalContentAlignment="Center"   Width="600" Height="600" FontSize="50" Canvas.Left="189" Canvas.Top="85" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Label.Background>
                    <SolidColorBrush Color="#FF636363" Opacity="0.5"/>
                </Label.Background>
                <Run Text="AD廣告" FontWeight="Bold"/>
            </Label>
            <Ellipse Fill="#FF636363" Opacity="12" Width="600" Height="600" Canvas.Left="869" Canvas.Top="85" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <Label Content="請輸入密碼" HorizontalAlignment="Center" VerticalContentAlignment="Center" Height="63" FontSize="30" Canvas.Left="1089" Canvas.Top="212" Foreground="White" FontFamily="Yu Gothic UI Semibold" VerticalAlignment="Center"/>
            <TextBox x:Name="PasswordTextBox" HorizontalAlignment="Center" Height="50" TextWrapping="Wrap" VerticalAlignment="Top" Width="338" Canvas.Left="1000" Canvas.Top="348" FontSize="30" Background="{x:Null}" Foreground="White"/>
            <Rectangle Width="338" Height="50" Canvas.Left="1004" Canvas.Top="435" HorizontalAlignment="Left" VerticalAlignment="Top" RadiusX="12" RadiusY="12">
                <Rectangle.Fill>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF3EBB07"/>
                        <GradientStop Color="#FF668A64" Offset="1"/>
                        <GradientStop Color="#FF2F631C" Offset="0.52"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Button Content="登入" HorizontalAlignment="Left" VerticalAlignment="Top" Width="338" Height="50" Canvas.Left="1004" Canvas.Top="435" FontSize="30"  Background="{x:Null}" Foreground="White" BorderBrush="{x:Null}" Click="Button_Click"/>

            <Label Content="Please enter password" VerticalContentAlignment="Center" Height="52" FontSize="30" Canvas.Left="1012" Canvas.Top="264" Foreground="White" FontFamily="Yu Gothic UI Semibold" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        </Canvas>
    </Grid>
</Page>
