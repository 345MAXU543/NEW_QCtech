<Window x:Class="NEW_QCtech.GlobalSetting"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NEW_QCtech"
        mc:Ignorable="d"
        Title="GlobalSetting" Height="800" Width="1000" 
        Background="Transparent" WindowStyle="None" ResizeMode="CanResize" AllowsTransparency="True" WindowStartupLocation="CenterScreen">
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="-1"/>
    </WindowChrome.WindowChrome>
    <Window.Template>
        <ControlTemplate TargetType="Window">
            <Border Padding="0" Background="Transparent">
                <Border CornerRadius="16">
                    <Border.Background>
                        <SolidColorBrush Color="White" Opacity="0.25"/>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="64" />
                    </Border.Effect>
                    <ContentPresenter ClipToBounds="True" />
                </Border>
            </Border>
        </ControlTemplate>
    </Window.Template>
    <Grid Margin="20,20,20,20" ScrollViewer.HorizontalScrollBarVisibility="Auto">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TreeView x:Name="LeftSideTreeView" Width="144" Grid.Row="0" Grid.Column="0" Grid.RowSpan="2"  Background="#FF797777" Foreground="White" BorderBrush="White" 
                  SelectedItemChanged="LeftSideTreeView_SelectedItemChanged">

            <TreeView.Resources>
                <Style TargetType="TreeViewItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="White"/>

                     
                </Style>   
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF49A23D"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#FF49A23D"/>

                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White"/>
            </TreeView.Resources>
            
            <TreeViewItem Header="硬體" Foreground="White" FontSize="25"/>
            <TreeViewItem Header="保護" Foreground="White" FontSize="25"/>
            <TreeViewItem Header="使用者介面" Foreground="White" FontSize="25">
                <TreeViewItem Header="曲線圖" Foreground="White" FontSize="25"/>
                <TreeViewItem Header="表格" Foreground="White" FontSize="25"/>
                <TreeViewItem Header="數值即時顯示" x:Name="CardPanel" Foreground="White" FontSize="25"/>
            </TreeViewItem>
            <TreeViewItem Header="常規" Foreground="White" FontSize="25">
                <TreeViewItem Header="單位" Foreground="White" FontSize="25"/>
            </TreeViewItem>
            <TreeViewItem Header="保護" Foreground="White" FontSize="25"/>

        </TreeView>


        <Frame Grid.Column="1"    x:Name="Frame_context" Grid.RowSpan="2"  Margin="10,0,0,0" Background="Black" NavigationUIVisibility="Hidden">

        </Frame>


    </Grid>
</Window>

