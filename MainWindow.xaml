                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="40*"/>
                </Grid.RowDefinitions>

                <GridSplitter Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="1" HorizontalAlignment="Stretch" Height="3" Foreground="{x:Null}">
                    <GridSplitter.Background>
                        <SolidColorBrush Color="#FFF0F0F0" Opacity="0.5"/>
                    </GridSplitter.Background>
                </GridSplitter>
                <GridSplitter Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="1" Grid.RowSpan="3" HorizontalAlignment="Stretch" Width="3">
