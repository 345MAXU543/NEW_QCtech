                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF3A4560" Offset="0.0"/>
                        <GradientStop Color="#FF1E2433" Offset="0.18"/>
                        <GradientStop Color="#FF0E0E13" Offset="0.50"/>
                        <GradientStop Color="#FF1E2433" Offset="0.82"/>
                        <GradientStop Color="#FF3A4560" Offset="1.0"/>
                    </LinearGradientBrush>
                </ScrollViewer.Background>
