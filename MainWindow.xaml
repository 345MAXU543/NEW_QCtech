                                    <Setter Property="FontSize" Value="18"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Background" Value="#FF222838"/>
                                </Style>
                            </DataGrid.RowHeaderStyle>
                        </DataGrid>




