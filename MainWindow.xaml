                                    <RowDefinition Height="1*"/>
                                </Grid.RowDefinitions>

                                <!-- 背景（整張卡） -->
                                <Grid
Grid.RowSpan="2"
Grid.ColumnSpan="3">
                                    <Grid.Background>
                                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                            <LinearGradientBrush.RelativeTransform>
                                                <TransformGroup>
                                                    <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                                                    <SkewTransform CenterX="0.5" CenterY="0.5"/>
                                                    <RotateTransform Angle="-45" CenterX="0.5" CenterY="0.5"/>
                                                    <TranslateTransform/>
                                                </TransformGroup>
                                            </LinearGradientBrush.RelativeTransform>
                                            <GradientStop Color="#FF0A5400"/>
                                            <GradientStop Color="#FF49A23D" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Grid.Background>
                                </Grid>

                                <!-- 大數字 -->
                                <Viewbox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Left">
                                    <Label Grid.Row="0" Grid.Column="0" Content="00" FontWeight="Bold" Foreground="White" Padding="2,0,2,0"/>
                                </Viewbox>

                                <!-- 小標題 -->
                                <Viewbox  Grid.Row="1" Grid.Column="0" HorizontalAlignment="Left">
                                    <Label Content="Axie1 Position(mm)" Foreground="White" Padding="5,0,0,0"/>
                                </Viewbox>


                                <!-- 右側圖示（最簡單：Emoji） -->
                                <Label Grid.RowSpan="2" Grid.Column="2"
