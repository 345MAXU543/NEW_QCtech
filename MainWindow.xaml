           PreviewMouseMove="CardsPanel_PreviewMouseMove"
           DragOver="CardsPanel_DragOver"
           Drop="CardsPanel_Drop" ContextMenu="{StaticResource CardsPanelContextMenu}">
                    <Border Margin="0" Tag="Card" Background="Transparent">
                        <Viewbox>
                            <Grid Margin="10" Width="350" Height="130">
                                <!-- 陰影 -->
                                <Grid.Effect>
                                    <DropShadowEffect ShadowDepth="15" BlurRadius="15" Opacity="0.4"/>
                                </Grid.Effect>

                                <!-- 版面 -->
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
