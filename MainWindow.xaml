<Window x:Class="NEW_QCtech.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NEW_QCtech"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="1000" Width="1600" WindowStartupLocation="CenterScreen" WindowStyle="None" ResizeMode="CanResize" Loaded="Window_Loaded" MouseMove="Window_MouseMove">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
        CaptionHeight="0"
        ResizeBorderThickness="8"
        CornerRadius="0"
        GlassFrameThickness="0"
        UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <ContextMenu x:Key="PlotContextMenu">
            <MenuItem Header="曲線圖設定" />
        </ContextMenu>

        <ContextMenu x:Key="CardsPanelContextMenu">
            <MenuItem Header="數據顯示卡設定"  Click="CardsPanel_Setting"/>
        </ContextMenu>
    </Window.Resources>


    <Grid x:Name="MainWindow_PeripheryGrid" Background="#FF5696AB">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- alert -->
            <RowDefinition Height="Auto"/>
            <!-- 即時資訊 -->
            <RowDefinition Height="5"/>
            <!-- splitter -->
            <RowDefinition Height="*"/>
            <!-- ★ 主工作區 -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <!-- footer -->
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10"/>
            <!-- 左邊框 -->
            <ColumnDefinition/>
            <!-- 主工作區 -->
            <ColumnDefinition Width="Auto" MinWidth="480"/>
            <!-- 右上控制列 -->
            <ColumnDefinition Width="10"/>
            <!-- 右邊框 -->

        </Grid.ColumnDefinitions>

        <Label x:Name="label_Alert"
               Grid.Row="0" Grid.Column="0" Grid.RowSpan="1" Grid.ColumnSpan="2"
               Content="警告訊息 或是 狀態" FontSize="16"  Background="Transparent" Margin="0,0,0,3"  MouseMove="label_Alert_MouseMove"/>

        <!--新增檔案 儲存 另存新檔 開啟檔案 最小化 最大化 叉叉控制箱-->
        <Border Grid.Column="2" Grid.ColumnSpan="1" Background="#FF65735F"  Grid.Row="0" Margin="0,5,0,0" MinWidth="160">
            <Grid>
                <Grid.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF5696AB"/>
                        <GradientStop Color="#FF222838" Offset="1"/>
                        <GradientStop Color="#FF222838" Offset="0.26"/>
                    </LinearGradientBrush>
                </Grid.Background>
                <Grid.ColumnDefinitions>
                    <!-- 左側工具列：永遠 auto -->
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>

                    <!-- 中間：唯一可被壓縮的區域 -->
                    <ColumnDefinition Width="*" MinWidth="0"/>

                    <!-- 右側視窗控制鍵：永遠顯示 -->
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="🗋" FontSize="20" Width="40" Height="30" Background="Transparent" Foreground="White" BorderBrush="#FFB2CBF6" HorizontalAlignment="Left" BorderThickness="1,1,1,0" />
                <Button Grid.Column="1" Content="💾" FontSize="20" Width="40" Height="30" Background="Transparent" Foreground="White" BorderBrush="#FFB2CBF6" HorizontalAlignment="Left" BorderThickness="1,1,1,0"/>
                <Button Grid.Column="2" Content="🗄" FontSize="20" Width="40" Height="30" Background="Transparent" Foreground="White" BorderBrush="#FFB2CBF6" HorizontalAlignment="Left" BorderThickness="1,1,1,0" />
                <Button Grid.Column="3" Content="📂" FontSize="20" Width="40" Height="30" Background="Transparent" Foreground="White" BorderBrush="#FFB2CBF6" HorizontalAlignment="Left" BorderThickness="1,1,1,0" />

                <Grid Grid.Column ="4" Height="30" Margin="5,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="1*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Image x:Name="Image_CompanyTrademark" Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"  Height="30" Width="30"  VerticalAlignment="Center" Source="/13.png" Stretch="Fill" RenderTransformOrigin="0.5,0.5" HorizontalAlignment="Left" />
                    <Label  Grid.Column="1" Grid.Row="0" Grid.RowSpan="2" Content="Yang YI" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="5,0,0,0" Padding="0,0,0,0"/>
                    <Label Grid.Column="3" Grid.Row="1" Content="technology" FontSize="10" Foreground="White" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5,0,0,0" Padding="0,0,0,0"/>


                </Grid>

                <Button x:Name="btn_GlobalSetting" Grid.Column="5" Content="S" FontSize="20" Width="40" Height="30" Background="Transparent" Foreground="White" BorderBrush="#FFB2CBF6" HorizontalAlignment="Right" BorderThickness="1,1,1,0" Click="btn_GlobalSetting_Click"/>
                <Button Grid.Column="6" Content="🗕" FontSize="20" Width="40" Height="30" Background="Transparent" Foreground="White" BorderBrush="#FFB2CBF6" HorizontalAlignment="Right" BorderThickness="1,1,1,0" Click="MinimizeButton_Click"/>
                <Button Grid.Column="7" Content="🗗" FontSize="20" Width="40" Height="30" Background="Transparent" Foreground="White" BorderBrush="#FFB2CBF6" HorizontalAlignment="Right" BorderThickness="1,1,1,0" Click="RestoreDownButton_Click"/>
                <Button Grid.Column="8" Content="✕" FontSize="20" Width="40" Height="30" Background="Transparent" Foreground="White" BorderBrush="#FFB2CBF6" HorizontalAlignment="Right" BorderThickness="1,1,1,0" Click="CloseButton_Click"/>
            </Grid>
        </Border>

